# Copy to .env and fill in. Never commit .env.

# App
APP_ENV=development
LOG_LEVEL=INFO
API_KEY=dev-local-key

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000

# Infra (used from M3/M4 onward; harmless to set now)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/debate
REDIS_URL=redis://localhost:6379/0

# LLM provider keys (wired in M2; leave blank to use the mock provider)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
